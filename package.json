{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "esbuild server.ts --bundle --platform=node --format=esm --packages=external --outfile=server.mjs && node server.mjs",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "brain:generate": "tsx generate-brain.ts",
    "brain:verify": "tsx brain/rules/validate-rules.ts",
    "brain:drift-check": "tsx brain/drift-check.ts",
    "brain:impact": "tsx brain/impact/analyze-impact.ts",
    "brain:embed": "tsx brain/embeddings/embedding-engine.ts",
    "brain:retrieve": "tsx brain/retrieval/retrieve-context.ts",
    "brain:retrieve-semantic": "tsx brain/retrieval/retrieve-semantic.ts",
    "brain:query": "tsx brain/knowledge/query-engine.ts",
    "brain:memory": "tsx brain/tasks/task-memory.ts",
    "brain:runtime-benchmark": "tsx brain/runtime/run-runtime-benchmark.ts",
    "brain:self-audit": "tsx brain/self-audit.ts",
    "brain:execute": "tsx brain/runtime/task-executor.ts",
    "brain:install-hooks": "tsx scripts/install-brain-hooks.ts",
    "brain:postchange": "tsx brain/autonomy/postchange.ts",
    "brain:auto": "tsx brain/autonomy/watch.ts",
    "brain:debug": "tsx brain/debug/debug-runner.ts",
    "brain:docs:sync": "tsx brain/debug/docs-sync.ts",
    "brain:ui-regression": "tsx brain/debug/ui-regression-probe.ts",
    "format:check": "prettier --check server.ts generate-brain.ts package.json TUTOR_ARCHITECTURE.md brain/architecture.md \"brain/**/*.ts\" \"scripts/**/*.ts\" skills/**/*.md src/views/AdminView.tsx src/views/RevisionView.tsx src/lib/tutorBook.json",
    "format": "prettier --write server.ts generate-brain.ts package.json TUTOR_ARCHITECTURE.md brain/architecture.md \"brain/**/*.ts\" \"scripts/**/*.ts\" skills/**/*.md src/views/AdminView.tsx src/views/RevisionView.tsx src/lib/tutorBook.json"
  },
  "dependencies": {
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/space-grotesk": "^5.2.10",
    "@google/genai": "^1.29.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "@xenova/transformers": "^2.17.2",
    "d3": "^7.9.0",
    "dexie": "^4.4.2",
    "dexie-react-hooks": "^4.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "mermaid": "^11.15.0",
    "motion": "^12.23.24",
    "openai": "^6.39.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-force-graph-3d": "^1.29.1",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.1.0",
    "three": "^0.184.0",
    "vite": "^6.2.3",
    "ws": "^8.21.0",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/three": "^0.184.1",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.21",
    "dependency-cruiser": "^17.4.2",
    "esbuild": "^0.25.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.14",
    "ts-morph": "^28.0.0",
    "tsx": "^4.19.1",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-node": "^6.0.0"
  }
}
