# LearningAI local development environment.
# Copy to .env and fill only the providers you plan to use.

# OpenRouter powers normal chat plus the custom foreground/background voice
# broker. Keep shared server fallback disabled unless this is a trusted
# deployment where the owner accepts provider usage.
OPENROUTER_API_KEY=
ALLOW_SERVER_OPENROUTER_FALLBACK=false

# Deepgram powers streaming speech-to-text and Deepgram Aura text-to-speech.
DEEPGRAM_API_KEY=
ALLOW_SERVER_DEEPGRAM_FALLBACK=false

# Serper is used by legacy typed-chat web-search routes. The custom voice
# broker delegates web work to the background OpenRouter model instead.
SERPER_API_KEY=
ALLOW_SERVER_SERPER_FALLBACK=false

# Voice broker mode:
# - deepgram: Deepgram Voice Agent path.
# - custom: browser -> local broker -> OpenRouter foreground/background models.
VITE_VOICE_BROKER_MODE=deepgram
VOICE_FOREGROUND_MODEL=openai/gpt-4o-mini

# Background model id must be valid for the provider you call through
# OpenRouter. Do not use this as the Codex app runtime model id.
VOICE_BACKGROUND_MODEL=openai/gpt-5.5
GPT55_API_KEY=

VOICE_BROKER_STT_MODEL=nova-3
VOICE_BROKER_TTS_MODEL=aura-2-thalia-en
VITE_VOICE_BROKER_TTS_MODEL=aura-2-thalia-en
VOICE_BROKER_TTS_SAMPLE_RATE=48000
VOICE_BROKER_TTS_DEADLINE_MS=180

# Optional local Miso wrapper for experimental TTS. The server only accepts
# loopback hosts for this URL in the local voice broker.
MISO_TTS_API_URL=http://127.0.0.1:8080
MISO_TTS_TOKENIZER_MODEL=unsloth/Llama-3.2-1B

# Experimental fast-ack and browser speech fallbacks. Keep these false for
# ordinary Deepgram/OpenRouter testing.
VOICE_BROKER_FAST_ACK=false
VOICE_BROKER_FAST_ACK_TEXT=Okay.
VOICE_BROKER_FAST_ACK_FILE=
VITE_VOICE_BROKER_BROWSER_TTS=false
